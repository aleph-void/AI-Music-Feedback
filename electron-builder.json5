{
  appId: "com.aistreamer.app",
  productName: "AI Music Feedback",
  asar: true,
  directories: {
    output: "release"
  },
  files: [
    "out/**/*"
  ],
  extraResources: [
    {
      from: "src/public",
      to: "public",
      filter: ["**/*"]
    },
    {
      from: "resources/icon.png",
      to: "icon.png"
    }
  ],
  mac: {
    target: ["dmg", "zip"],
    icon: "resources/icon.png",
    category: "public.app-category.music",
    extendInfo: {
      NSAudioCaptureUsageDescription: "AI Music Feedback needs access to audio to stream your music to OpenAI for feedback.",
      NSMicrophoneUsageDescription: "AI Music Feedback needs microphone access to capture audio for AI feedback.",
      NSScreenCaptureDescription: "AI Music Feedback needs screen recording access to capture system audio."
    }
  },
  win: {
    target: ["nsis"],
    icon: "resources/icon.ico"
  },
  linux: {
    target: ["AppImage", "deb"],
    icon: "resources/icon.png",
    category: "Audio",
    maintainer: "Aleph Void LLC <contact@alephvoid.com>"
  },
  nsis: {
    oneClick: false,
    allowToChangeInstallationDirectory: true
  }
}
