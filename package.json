{
  "name": "ai-music-feedback",
  "version": "1.0.0",
  "description": "Stream desktop audio to OpenAI for real-time music feedback",
  "author": {
    "name": "Nick Starke",
    "email": "nstarke@users.noreply.github.com",
    "url": "https://github.com/aleph-void"
  },
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "vue-tsc --noEmit && electron-vite build",
    "pack": "npm run build && electron-builder",
    "pack:mac": "npm run build && electron-builder --mac",
    "pack:mac:x64": "npm run build && electron-builder --mac --x64",
    "pack:win": "npm run build && electron-builder --win",
    "pack:win:arm64": "npm run build && electron-builder --win --arm64",
    "pack:linux": "npm run build && electron-builder --linux",
    "pack:linux:arm64": "npm run build && electron-builder --linux --arm64",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:electron": "vitest run --project electron-main",
    "test:renderer": "vitest run --project renderer",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "vue": "^3.5.32",
    "vue-i18n": "^11.3.2"
  },
  "devDependencies": {
    "@intlify/unplugin-vue-i18n": "^11.1.2",
    "@playwright/test": "^1.59.1",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.2",
    "@vue/test-utils": "^2.4.8",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "happy-dom": "^20.9.0",
    "typescript": "^6.0.3",
    "vite": "^7.0.0",
    "vitest": "^4.1.2",
    "vue-tsc": "^3.2.7"
  }
}
