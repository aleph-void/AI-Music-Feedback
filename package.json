{
  "name": "ai-streamer",
  "version": "1.0.0",
  "description": "Stream desktop audio to OpenAI for real-time music feedback",
  "author": {
    "name": "Nick Starke",
    "email": "nstarke@users.noreply.github.com",
    "url": "https://github.com/nstarke"
  },
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "vue-tsc --noEmit && electron-vite build",
    "pack": "npm run build && electron-builder",
    "pack:mac": "npm run build && electron-builder --mac",
    "pack:mac:x64": "npm run build && electron-builder --mac --x64",
    "pack:win": "npm run build && electron-builder --win",
    "pack:win:arm64": "npm run build && electron-builder --win --arm64",
    "pack:linux": "npm run build && electron-builder --linux",
    "pack:linux:arm64": "npm run build && electron-builder --linux --arm64",
    "test": "vitest run --workspace vitest.workspace.ts",
    "test:watch": "vitest --workspace vitest.workspace.ts",
    "test:ui": "vitest --workspace vitest.workspace.ts --ui",
    "test:coverage": "vitest run --workspace vitest.workspace.ts --coverage",
    "test:electron": "vitest run --workspace vitest.workspace.ts --project electron-main",
    "test:renderer": "vitest run --workspace vitest.workspace.ts --project renderer",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "vue": "^3.4.0",
    "vue-i18n": "^9.14.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vitest/coverage-v8": "^2.1.9",
    "@vitest/ui": "^2.1.9",
    "@vue/test-utils": "^2.4.6",
    "electron": "^33.0.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^2.3.0",
    "happy-dom": "^20.8.9",
    "typescript": "^5.4.0",
    "vite": "^5.0.0",
    "vitest": "^2.1.9",
    "vue-tsc": "^3.2.6"
  }
}
